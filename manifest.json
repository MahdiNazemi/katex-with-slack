{
  "content_scripts": [
    {
      "matches": [
        "*://*.slack.com/*"
      ],
      "all_frames": true,
      "run_at": "document_idle",
      "css": [
        "katex.css"
      ],
      "js": [
        "katex.js",
        "auto-render.js",
        "glue.js"
      ]
    }
  ],
  "manifest_version": 3,
  "name": "LaTeX in Slack",
  "short_name": "latex-slack",
  "description": "Render LaTeX in Slack chat.",
  "author": "Mahdi Nazemi",
  "version": "1.0.9",
  "icons": {
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["fonts/*", "katex.css"],
      "matches": ["*://*.slack.com/*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "{d982df24-e6e9-43ea-904e-6adef6e289cc}"
    }
  }
}